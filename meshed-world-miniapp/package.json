{
  "name": "meshed-world-miniapp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "hardhat test",
    "test:all": "npm run test && npm run test:contracts",
    "hardhat:compile": "hardhat compile",
    "hardhat:deploy:coston2": "hardhat run scripts/deploy.ts --network coston2",
    "hardhat:deploy:meshing:coston2": "hardhat run scripts/deploy-meshing.ts --network coston2",
    "hardhat:deploy:worldchain-sepolia": "hardhat run scripts/deploy-verified-interaction-registry.js --network worldchainSepolia",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:setup": "./scripts/setup_db.sh",
    "db:reset": "docker compose down -v && docker compose up -d",
    "onboarding:reset": "node scripts/reset-onboarding-progress.mjs",
    "world:reset-replay": "node scripts/reset-world-replay-mappings.mjs",
    "prisma:generate": "node scripts/run-prisma-with-db-url.cjs generate",
    "prisma:migrate": "node scripts/run-prisma-with-db-url.cjs migrate dev",
    "prisma:seed": "node scripts/run-prisma-with-db-url.cjs db seed",
    "db:push": "node scripts/run-prisma-with-db-url.cjs db push",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dynamic-labs-sdk/client": "0.23.2",
    "@dynamic-labs/embedded-wallet-evm": "4.75.0",
    "@dynamic-labs/sdk-react-core": "4.75.0",
    "@dynamic-labs/waas-evm": "4.75.0",
    "@openzeppelin/contracts": "^5.2.0",
    "@prisma/client": "^6.0.0",
    "@worldcoin/idkit": "^4.0.11",
    "@worldcoin/idkit-core": "^4.1.0",
    "@worldcoin/minikit-js": "^2.0.3",
    "clsx": "^2.1.1",
    "ethers": "^6.13.5",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "openai": "^6.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "siwe": "^3.0.0",
    "tailwind-merge": "^2.6.0",
    "viem": "^2.48.4",
    "vis-network": "^10.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "15.5.14",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.14",
    "hardhat": "^2.22.18",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
