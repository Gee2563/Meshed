generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COMPANY
  CONSULTANT
  MENTOR
  OPERATOR
  INVESTOR
  ADMIN
}

enum CompanyKind {
  VC
  PORTFOLIO
  OPERATING
}

enum RegistrationFlowStep {
  VC_COMPANY
  PORTFOLIO_COMPANY
  COMPANY_ACCESS
  INDIVIDUAL_PROFILE
  COMPLETE
}

enum OnboardingMode {
  COMPANY
  INDIVIDUAL
}

model User {
  id                          String              @id
  name                        String
  email                       String              @unique
  role                        UserRole
  bio                         String              @default("")
  skills                      String[]
  sectors                     String[]
  linkedinUrl                 String?
  walletAddress               String?             @unique
  worldVerified               Boolean             @default(false)
  dynamicUserId               String?             @unique
  engagementScore             Int                 @default(0)
  reliabilityScore            Int                 @default(0)
  verificationBadges          String[]
  outsideNetworkAccessEnabled Boolean             @default(false)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  lastActiveAt                DateTime?
  companiesOwned              Company[]           @relation("CompanyOwner")
  memberships                 CompanyMembership[]
}

model Company {
  id                          String              @id
  name                        String
  description                 String
  sector                      String
  stage                       String
  website                     String
  ownerUserId                 String
  currentPainTags             String[]
  resolvedPainTags            String[]
  companyKind                 CompanyKind         @default(OPERATING)
  parentCompanyId             String?
  outsideNetworkAccessEnabled Boolean             @default(false)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  owner                       User                @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  memberships                 CompanyMembership[]
}

model CompanyMembership {
  id        String   @id
  companyId String
  userId    String
  relation  String
  title     String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, relation])
}

model OnboardingProfile {
  id                    String               @id
  userId                String               @unique
  companyId             String?
  vcCompanyId           String?
  portfolioCompanyId    String?
  mode                  OnboardingMode
  title                 String
  isExecutive           Boolean
  executiveSignoffEmail String?
  currentStep           RegistrationFlowStep @default(VC_COMPANY)
  teamCsvUploadedAt     DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}
