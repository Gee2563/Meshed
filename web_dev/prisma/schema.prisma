generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COMPANY
  CONSULTANT
  MENTOR
  OPERATOR
  INVESTOR
  ADMIN
}


enum CompanyKind {
  VC
  PORTFOLIO
  OPERATING
}

enum RegistrationFlowStep {
  VC_COMPANY
  PORTFOLIO_COMPANY
  COMPANY_ACCESS
  INDIVIDUAL_PROFILE
  COMPLETE
}

enum OnboardingContractStep {
  VC_COMPANY_REGISTERED
  PORTFOLIO_COMPANY_REGISTERED
  COMPANY_ACCESS_REGISTERED
  INDIVIDUAL_PROFILE_REGISTERED
  WORLD_VERIFIED
}

enum ContractGenerationMode {
  MOCK
  REAL
}

model User {
  id                  String               @id
  name                String
  email               String               @unique
  role                UserRole
  bio                 String               @default("")
  skills              String[]
  sectors             String[]
  linkedinUrl         String?
  walletAddress       String?              @unique
  worldVerified       Boolean              @default(false)
  dynamicUserId       String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastActiveAt        DateTime?
  companiesOwned      Company[]            @relation("CompanyOwner")
  memberships         CompanyMembership[]
  onboardingProfile   OnboardingProfile?
  onboardingContracts OnboardingContractArtifact[]
}

model Company {
  id                        String                     @id
  name                      String
  description               String
  sector                    String
  stage                     String
  website                   String
  ownerUserId               String
  currentPainTags           String[]
  resolvedPainTags          String[]
  companyKind               CompanyKind                @default(OPERATING)
  parentCompanyId           String?
  outsideNetworkAccessEnabled Boolean                  @default(false)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  owner                     User                       @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  parentCompany             Company?                   @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id], onDelete: SetNull)
  portfolioCompanies        Company[]                  @relation("CompanyHierarchy")
  memberships               CompanyMembership[]
  onboardingProfiles        OnboardingProfile[]
  onboardingContracts       OnboardingContractArtifact[]
}

model CompanyMembership {
  id        String   @id
  companyId String
  userId    String
  relation  String
  title     String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, relation])
}
